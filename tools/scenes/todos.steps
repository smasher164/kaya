# The todos round trip: type, add, toggle the stamped row's checkbox
# (a field-level update), and read the items-left label.
# The opening expect doubles as the scene-ready wait
expect label#0 "0 items left"
set_text entry#0 "buy milk"
click button#0
expect entry#0 ""
expect_focused entry#0
toggle checkbox#0 on
expect label#0 "0 items left"
